{
  "name": "mfe-ecommerce",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  },
  "overrides": {
    "enhanced-resolve": "5.18.1"
  },
  "scripts": {
    "dev1": "concurrently \"npm run dev -w host\" \"npm run dev -w remote-products\"",
    "dev": "concurrently \"npm run dev -w packages/host\" \"npm run dev -w packages/remote-products\" \"npm run dev -w packages/remote-cart\" \"npm run dev -w packages/remote-orders\"",
    "dev:app": "node scripts/dev-app.mjs",
    "build:all": "npm run build -w packages/remote-products && npm run build -w packages/remote-cart && npm run build -w packages/remote-orders && npm run build -w packages/host",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "type-check": "npm run type-check --workspaces --if-present",
    "type-check:root": "tsc --noEmit -p tsconfig.base.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "concurrently": "latest",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.23",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^26.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
