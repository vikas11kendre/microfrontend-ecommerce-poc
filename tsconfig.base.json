{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "shared-ui": ["packages/shared-ui/src/index.ts"],
      "shared-ui/*": ["packages/shared-ui/src/*"],
      "shared-store": ["packages/shared-store/src/index.ts"],
      "shared-store/*": ["packages/shared-store/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".turbo", ".next"]
}
